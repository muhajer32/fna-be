# Virtual environment and secrets
.venv/
.env
.env.local
.env.*.local
!.env.example

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.mypy_cache/
.pytest_cache/

# macOS
.DS_Store
~$*

# Logs
logs/

# Data: track ONLY sample data, the demo workbook, and PECD download instructions.
# Everything else under data/ is generated, large, or restricted
# (data/inputs/raw_*, data/outputs/runs, PECD payload, ...).
data/*
!data/inputs/
data/inputs/*
!data/inputs/sample/
!data/inputs/sample/**
!data/inputs/pecd/
data/inputs/pecd/*
!data/inputs/pecd/README.md
!data/inputs/excel/
data/inputs/excel/*.xlsx
!data/inputs/excel/demo_input.xlsx
data/inputs/excel/~$*

# Tooling / IDE
.claude/
.idea/
.vscode/
