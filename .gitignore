# Virtual environment and secrets
.venv/
.env
.env.local
.env.*.local
!.env.example

# Python artefacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.mypy_cache/
.pytest_cache/

# macOS
.DS_Store
~$*

# Logs
logs/

# Data: track ONLY sample data (+ the PECD download instructions).
# Everything else under data/ is generated, large, or restricted
# (data/inputs, data/outputs/runs, data/raw_be2023, data/pecd payload, ...).
data/*
!data/sample/
!data/pecd/
data/pecd/*
!data/pecd/README.md

# Excel: track ONLY the demo workbook. All other workbooks, lock files and
# pulled VM run outputs are local/generated.
excel/*.xlsx
!excel/demo_input.xlsx
excel/~$*
excel/vmmc/

# Tooling / IDE
.claude/
.idea/
.vscode/
