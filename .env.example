# Copy this file to .env (or .venv/.env) and fill in your values.
# Never commit the actual .env file.

# Required for: python -m fna fetch
ENTSOE_API_KEY=

# Required for: python -m fna run / mc
# Point to the `gams` binary on your system.
GAMS_EXE=/path/to/gams
GAMS_TIMEOUT=1500

# Optional: path to your local PECD download (see data/inputs/pecd/README.md)
PECD_DATA_DIR=./data/inputs/pecd

# Optional overrides (defaults come from 01_Control sheet in the workbook)
# REPRESENTATIVE_DAY_CLUSTERS=10
# MAX_PARALLEL_WORKERS=4
# MC_RESUME_EXISTING=false
